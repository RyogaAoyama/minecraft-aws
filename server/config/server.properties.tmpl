# Minecraft server.properties テンプレート（Fabric 1.21.11）
# install.sh が __RCON_PASSWORD__ / __RCON_PORT__ を実値へ置換して
# /opt/minecraft/server/server.properties を生成する。
# 生成後のファイルは RCON パスワードを含むためリポジトリにはコミットしない。

# ワールドフォルダ名（クライアント MOD の Voxy などが世界識別子として参照する）
level-name=kiki-kinako

# 接続ポート（SecurityGroupで25565/tcpのみ公開）
server-port=25565

# 正規アカウント認証（割れ対策・推奨）
online-mode=true

# 少人数運用
max-players=10

motd=Minecraft on AWS (spot)

# RCON: アイドル監視/保存制御のためローカル(127.0.0.1)からのみ利用。
# RCONポートはSecurityGroupで外部公開しない。
enable-rcon=true
rcon.port=__RCON_PORT__
rcon.password=__RCON_PASSWORD__

# クエリは使わない
enable-query=false

# 性能/運用上の既定
view-distance=8
simulation-distance=6
difficulty=easy
spawn-protection=0
white-list=true
enforce-whitelist=true
sync-chunk-writes=false
network-compression-threshold=512
region-file-compression=lz4

# Minecraft 1.21+ のサーバ空時 tick 停止機能。デフォルト 60s でアイドル時に
# server thread が pause するため、観測系 (spark sampler や JFR の Java event)
# が data を集められなくなる。観測ログ基盤前提で常時 tick を維持する。
# アイドル停止は別途 idle-check.sh が RCON list の player 数で判定するため、
# 常時 tick でもインスタンス自動停止には影響しない (CPU 増加分のみ)。
pause-when-empty-seconds=0
